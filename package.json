{
  "name": "wanderlust-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/main.ts",
    "build": "tsc -b && vite build",
    "start": "node server/main.js",
    "start:prod": "cross-env NODE_ENV=production node server/main.js",
    "test": "node --import tsx --test tests/validation.test.ts tests/search.test.ts tests/env.test.ts tests/auth.test.ts tests/app.test.ts",
    "check": "npm run build && npm test",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.10",
    "pg": "^8.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
